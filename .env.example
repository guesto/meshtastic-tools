# Meshtastic Tools Environment Variables
# Copy this file to .env and adjust as needed

# Configuration file path (overrides default search paths)
MESHTASTIC_TOOLS_CONFIG=/home/guesto/OPT/meshtastic-tools/config/meshtastic-tools.yaml

# Log level (DEBUG, INFO, WARNING, ERROR)
MESHTASTIC_LOG_LEVEL=INFO

# Environment (development, production)
MESHTASTIC_ENV=development